# --- Stream (required for WebRTC transport) ---
STREAM_API_KEY=your_key_here
STREAM_API_SECRET=your_secret_here

# --- LLM Provider: pick ONE block and uncomment ---

# OPTION A: Google Gemini (free tier via AI Studio)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key_here

# OPTION B: Groq (free tier, OpenAI-compatible, 6000 req/day)
# LLM_PROVIDER=groq
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=your_groq_key_here
# LLM_MODEL=llama-3.3-70b-versatile

# OPTION C: Ollama local (tunnel with: ngrok http 11434)
# LLM_PROVIDER=ollama
# LLM_BASE_URL=https://YOUR_NGROK_ID.ngrok-free.app/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2-vision

# --- Speech ---
DEEPGRAM_API_KEY=your_deepgram_key_here   # free tier: 200hrs/month

# --- Decart (optional — enables live AI video restyling) ---
# DECART_API_KEY=your_decart_key_here

# --- Frontend (for CORS) ---
FRONTEND_URL=https://your-project.vercel.app
